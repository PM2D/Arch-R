		15 00 02 86 0f
		15 00 02 87 0e
		15 00 02 88 0e
		15 00 02 89 06
		15 00 02 8a 06
		15 00 02 8b 07
		15 00 02 8c 07
		15 00 02 8d 04
		15 00 02 8e 04
		15 00 02 8f 05
		15 00 02 90 05
		15 00 02 98 0f
		15 00 02 99 0f
		15 00 02 9a 00

/*
 * Arch R - Game Console R36S device tree for kernel 6.6
 *
 * Based on rk3326-odroid-go.dtsi (proven kernel 6.6 base)
 * Joypad adapted from EatPrilosec R36S DTS (odroidgo3-joypad → adc-joystick)
 * Panel init from R36S-DTB Panel 4 V22 (simple-panel-dsi + panel-init-sequence)
 *
 * Copyright (C) 2024-2025 Arch R Project
 * Copyright (C) 2022-24 JELOS (joypad layout reference)
 */

/dts-v1/;
#include "rk3326-odroid-go.dtsi"

/ {
	model = "Game Console R36S";
	compatible = "gameconsole,r35s", "gameconsole,r36s", "rockchip,rk3326";

	aliases {
		mmc0 = &sdio;   /* R36S internal SD (SDIO controller) */
		mmc1 = &sdmmc;  /* R36S external SD */
	};

	/*
	 * ADC mux for dual analog sticks
	 * Same hardware as ODROID GO Super: GPIO mux selects between
	 * 4 analog axes via single SARADC channel 1
	 */
	joystick_mux_controller: mux-controller {
		compatible = "gpio-mux";
		pinctrl = <&mux_en_pins>;
		#mux-control-cells = <0>;
		mux-gpios = <&gpio3 RK_PB3 GPIO_ACTIVE_LOW>,
			    <&gpio3 RK_PB0 GPIO_ACTIVE_LOW>;
	};

	joystick_mux: adc-mux {
		compatible = "io-channel-mux";
		io-channels = <&saradc 1>;
		io-channel-names = "parent";
		#io-channel-cells = <1>;
		mux-controls = <&joystick_mux_controller>;
		channels = "0", "1", "2", "3";
	};

	analog_sticks: adc-joystick {
		compatible = "adc-joystick";
		io-channels = <&joystick_mux 0>,
			      <&joystick_mux 1>,
			      <&joystick_mux 2>,
			      <&joystick_mux 3>;
		poll-interval = <60>;
		#address-cells = <1>;
		#size-cells = <0>;

		/* Left stick X: inverted on R36S (abs-range swapped) */
		axis@0 {
			reg = <0>;
			abs-flat = <10>;
			abs-fuzz = <10>;
			abs-range = <800 180>;
			linux,code = <ABS_X>;
		};

		/* Right stick X: normal */
		axis@1 {
			reg = <1>;
			abs-flat = <10>;
			abs-fuzz = <10>;
			abs-range = <180 800>;
			linux,code = <ABS_RX>;
		};

		/* Left stick Y: inverted on R36S (abs-range swapped) */
		axis@2 {
			reg = <2>;
			abs-flat = <10>;
			abs-fuzz = <10>;
			abs-range = <800 180>;
			linux,code = <ABS_Y>;
		};

		/* Right stick Y: normal */
		axis@3 {
			reg = <3>;
			abs-flat = <10>;
			abs-fuzz = <10>;
			abs-range = <180 800>;
			linux,code = <ABS_RY>;
		};
	};

	/* Volume buttons (separate from gamepad) */
	gpio-keys-vol {
		compatible = "gpio-keys";
		autorepeat;
		pinctrl-0 = <&btn_pins_vol>;
		pinctrl-names = "default";

		button-vol-down {
			gpios = <&gpio2 RK_PA1 GPIO_ACTIVE_LOW>;
			label = "VOLUMEDOWN";
			linux,code = <KEY_VOLUMEDOWN>;
		};

		button-volume-up {
			gpios = <&gpio2 RK_PA0 GPIO_ACTIVE_LOW>;
			label = "VOLUMEUP";
			linux,code = <KEY_VOLUMEUP>;
		};
	};

	/* Battery: R36S has 3200mAh (vs 4000mAh on ODROID GO Super) */
	battery: battery {
		compatible = "simple-battery";
		charge-full-design-microamp-hours = <3200000>;
		charge-term-current-microamp = <320000>;
		constant-charge-current-max-microamp = <2000000>;
		constant-charge-voltage-max-microvolt = <4200000>;
		factory-internal-resistance-micro-ohms = <180000>;
		voltage-max-design-microvolt = <4100000>;
		voltage-min-design-microvolt = <3500000>;

		ocv-capacity-celsius = <20>;
		ocv-capacity-table-0 =  <4046950 100>, <4001920 95>, <3967900 90>, <3919950 85>,
					<3888450 80>, <3861850 75>, <3831540 70>, <3799130 65>,
					<3768190 60>, <3745650 55>, <3726610 50>, <3711630 45>,
					<3696720 40>, <3685660 35>, <3674950 30>, <3663050 25>,
					<3649470 20>, <3635260 15>, <3616920 10>, <3592440 5>,
					<3574170 0>;
	};

	/* ============================================================
	 * Sound card: fix for BSP rk817 codec (kernel 6.6)
	 *
	 * Problem 1 (DAI mismatch): Base DTSI has sound-dai = <&rk817>.
	 * Adding compatible="rockchip,rk817-codec" causes MFD to assign
	 * the child's own of_node → codec registers under &rk817_codec,
	 * not &rk817 → ASoC DAI mismatch → "deferred probe pending".
	 * Fix: point sound-dai to the codec sub-node directly.
	 *
	 * Problem 2 (DAPM routing): Base DTSI defines routing referencing
	 * DAPM widgets MICL, HPOL, HPOR, SPKO. But the BSP rk817 codec
	 * driver does NOT register any DAPM widgets — it uses "Playback
	 * Path" / "Capture MIC Path" ALSA enums for path switching.
	 * → "Failed to add route" → card registration fails.
	 * Fix: remove routing and widgets (not used by BSP codec).
	 *
	 * Problem 3 (DAPM unknown pin): hp-det-gpio makes simple-audio-card
	 * create a "Headphones" DAPM jack pin. With widgets deleted,
	 * DAPM can't find the pin → "DAPM unknown pin Headphones".
	 * Fix: keep hp-det-gpio (needed for SW_HEADPHONE_INSERT events
	 * used by archr-hotkeys daemon) but re-add JUST the Headphone
	 * widget (no routing — BSP codec uses Playback Path enum).
	 * ============================================================ */
	rk817-sound {
		/delete-property/ simple-audio-card,routing;
		simple-audio-card,widgets = "Headphone", "Headphones";
		simple-audio-card,hp-det-gpio = <&gpio2 RK_PC6 GPIO_ACTIVE_LOW>;
		simple-audio-card,codec {
			sound-dai = <&rk817_codec>;
		};
	};
};

/* ============================================================
 * Remove ODROID-specific nodes not present on R36S
 * ============================================================ */
/delete-node/ &gpio_led;   /* R36S has no status LEDs */
/delete-node/ &pwm_led;    /* R36S has no PWM LED */
/* vcc_host regulator kept — needed for USB OTG VBUS power (GPIO0 PB7) */

/* Replace ODROID F1-F6 buttons with R36S-specific mapping */
/delete-node/ &btn_f1;     /* GPIO2 PA0 → volume down (separate node) */
/delete-node/ &btn_f2;     /* GPIO2 PA1 → volume up (separate node) */
/delete-node/ &btn_f3;     /* GPIO2 PA2 → BTN_THUMBL */
/delete-node/ &btn_f4;     /* GPIO2 PA3 → BTN_THUMBR */
/delete-node/ &btn_f5;     /* GPIO2 PA4 → BTN_MODE */
/delete-node/ &btn_f6;     /* GPIO2 PA5 → unused on R36S */

/* ============================================================
 * R36S gamepad buttons
 * Base (rk3326-odroid-go.dtsi) already has: DPAD, ABXY, TL, TR
 * We add: THUMBL, THUMBR, MODE, SELECT, START, TL2, TR2
 * ============================================================ */
&builtin_gamepad {
	button-thumbl {
		gpios = <&gpio2 RK_PA2 GPIO_ACTIVE_LOW>;
		label = "BTN_THUMBL";
		linux,code = <BTN_THUMBL>;
	};

	button-thumbr {
		gpios = <&gpio2 RK_PA3 GPIO_ACTIVE_LOW>;
		label = "BTN_THUMBR";
		linux,code = <BTN_THUMBR>;
	};

	button-mode {
		gpios = <&gpio2 RK_PA4 GPIO_ACTIVE_LOW>;
		label = "BTN_MODE";
		linux,code = <BTN_MODE>;
	};

	button-select {
		gpios = <&gpio3 RK_PB1 GPIO_ACTIVE_LOW>;
		label = "SELECT";
		linux,code = <BTN_SELECT>;
	};

	button-start {
		gpios = <&gpio3 RK_PB4 GPIO_ACTIVE_LOW>;
		label = "START";
		linux,code = <BTN_START>;
	};

	button-tl2 {
		gpios = <&gpio3 RK_PB2 GPIO_ACTIVE_LOW>;
		label = "TOP-LEFT 2";
		linux,code = <BTN_TL2>;
	};

	button-tr2 {
		gpios = <&gpio3 RK_PB7 GPIO_ACTIVE_LOW>;
		label = "TOP-RIGHT 2";
		linux,code = <BTN_TR2>;
	};
};

/* ============================================================
 * Panel: R36S 3.5" 640x480 MIPI-DSI (Panel 4 V22 init sequence)
 * Uses Rockchip BSP panel-simple.c with DTS-based init sequence
 * For multi-panel support: create overlay DTBOs or separate DTBs
 * ============================================================ */
&internal_display {
	compatible = "simple-panel-dsi";
	reset-gpios = <&gpio3 RK_PC0 GPIO_ACTIVE_LOW>;
	iovcc-supply = <&vcc_lcd>;
	vdd-supply = <&vcc_lcd>;
	backlight = <&backlight>;

	prepare-delay-ms = <20>;
	reset-delay-ms = <150>;
	init-delay-ms = <20>;
	enable-delay-ms = <120>;
	disable-delay-ms = <50>;
	unprepare-delay-ms = <20>;

	width-mm = <52>;
	height-mm = <70>;

	dsi,flags = <0xa03>;  /* VIDEO | BURST | LPM | EOT_PACKET */
	dsi,format = <0>;     /* MIPI_DSI_FMT_RGB888 */
	dsi,lanes = <4>;

	/* Panel 4 V22 MIPI DSI init sequence (from decompiled Panel4-V22.dts) */
	panel-init-sequence = [
		15 00 02 ff 30
		15 00 02 ff 52
		15 00 02 ff 01
		15 00 02 e3 00
		15 00 02 25 10
		15 00 02 28 6f
		15 00 02 29 01
		15 00 02 2a df
		15 00 02 2c 22
		15 00 02 c3 0f
		15 00 02 37 9c
		15 00 02 38 a7
		15 00 02 39 41
		15 00 02 80 20
		15 00 02 91 67
		15 00 02 92 67
		15 00 02 a0 55
		15 00 02 a1 50
		15 00 02 a3 58
		15 00 02 a4 9c
		15 00 02 a7 02
		15 00 02 a8 01
		15 00 02 a9 21
		15 00 02 aa fc
		15 00 02 ab 28
		15 00 02 ac 06
		15 00 02 ad 06
		15 00 02 ae 06
		15 00 02 af 03
		15 00 02 b0 08
		15 00 02 b1 26
		15 00 02 b2 28
		15 00 02 b3 28
		15 00 02 b4 03
		15 00 02 b5 08
		15 00 02 b6 26
		15 00 02 b7 08
		15 00 02 b8 26
		15 00 02 2c 22
		15 00 02 5c 40
		15 00 02 c0 00
		15 00 02 c1 00
		15 00 02 c2 00
		15 00 02 ff 30
		15 00 02 ff 52
		15 00 02 ff 02
		15 00 02 b0 02
		15 00 02 d0 02
		15 00 02 b1 0f
		15 00 02 d1 10
		15 00 02 b2 11
		15 00 02 d2 12
		15 00 02 b3 32
		15 00 02 d3 33
		15 00 02 b4 36
		15 00 02 d4 36
		15 00 02 b5 3c
		15 00 02 d5 3c
		15 00 02 b6 20
		15 00 02 d6 20
		15 00 02 b7 3e
		15 00 02 d7 3e
		15 00 02 b8 0e
		15 00 02 d8 0d
		15 00 02 b9 05
		15 00 02 d9 05
		15 00 02 ba 11
		15 00 02 da 12
		15 00 02 bb 11
		15 00 02 db 11
		15 00 02 bc 13
		15 00 02 dc 14
		15 00 02 bd 14
		15 00 02 dd 14
		15 00 02 be 16
		15 00 02 de 18
		15 00 02 bf 0e
		15 00 02 df 0f
		15 00 02 c0 17
		15 00 02 e0 17
		15 00 02 c1 07
		15 00 02 e1 08
		15 00 02 ff 30
		15 00 02 ff 52
		15 00 02 ff 03
		15 00 02 08 8a
		15 00 02 09 8b
		15 00 02 30 00
		15 00 02 31 00
		15 00 02 32 00
		15 00 02 33 00
		15 00 02 34 61
		15 00 02 35 d4
		15 00 02 36 24
		15 00 02 37 03
		15 00 02 40 86
		15 00 02 41 87
		15 00 02 42 84
		15 00 02 43 85
		15 00 02 44 11
		15 00 02 45 de
		15 00 02 46 dd
		15 00 02 47 11
		15 00 02 48 e0
		15 00 02 49 df
		15 00 02 50 82
		15 00 02 51 83
		15 00 02 52 80
		15 00 02 53 81
		15 00 02 54 11
		15 00 02 55 e2
		15 00 02 56 e1
		15 00 02 57 11
		15 00 02 58 e4
		15 00 02 59 e3
		15 00 02 82 0f
		15 00 02 83 0f
		15 00 02 84 00

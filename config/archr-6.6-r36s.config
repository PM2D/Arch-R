# ============================================================
# SIZE TRIM: Touchscreen/mouse/remote — R36S has none (~100-200KB)
# ============================================================
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_MOUSE_CYAPA is not set
# CONFIG_MOUSE_ELAN_I2C is not set
# CONFIG_ROCKCHIP_REMOTECTL is not set
# CONFIG_RK_HEADSET is not set

# ============================================================
# SIZE TRIM: SoC CPU configs — keep only PX30 (=RK3326) (~200-400KB)
# ============================================================
# CONFIG_CPU_RV1126B is not set
# CONFIG_CPU_RK1808 is not set
# CONFIG_CPU_RK3328 is not set
# CONFIG_CPU_RK3399 is not set
# CONFIG_CPU_RK3528 is not set
# CONFIG_CPU_RK3562 is not set
# CONFIG_CPU_RK3568 is not set
# CONFIG_CPU_RK3576 is not set
# CONFIG_CPU_RK3588 is not set
# CONFIG_ROCKCHIP_AMP is not set
# CONFIG_ARM_SMMU_V3 is not set
# CONFIG_EDAC is not set

# ============================================================
# SIZE TRIM: Wireless — disable BCMDHD (forces cfg80211 built-in)
# ============================================================
# CONFIG_BCMDHD is not set

# ============================================================
# SIZE TRIM: Bluetooth — modularize (USB dongles, not built-in)
# ============================================================
CONFIG_BT=m
CONFIG_BT_RFCOMM=m
CONFIG_BT_HIDP=m
CONFIG_BT_HCIBTUSB=m
# CONFIG_BT_HCIBFUSB is not set
# CONFIG_BT_HCIVHCI is not set
# CONFIG_BT_MRVL is not set
# CONFIG_BT_DEBUGFS is not set


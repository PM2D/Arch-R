# Arch R - Kernel 6.6 Config Fragment for R36S
# Apply on top of rockchip_linux_defconfig:
#   make rockchip_linux_defconfig
#   scripts/kconfig/merge_config.sh -m .config <this-file>
#   make olddefconfig

# ============================================================
# Version string: force "6.6.89-archr" (no git hash, no -dirty)
# ============================================================
CONFIG_LOCALVERSION="-archr"
# CONFIG_LOCALVERSION_AUTO is not set

# ============================================================
# Joystick / Gamepad (adc-joystick + gpio-mux)
# ============================================================
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_ADC=y

# ============================================================
# Multiplexer subsystem (gpio-mux + io-channel-mux)
# ============================================================
CONFIG_MULTIPLEXER=y
CONFIG_MUX_GPIO=y
CONFIG_IIO_MUX=y

# ============================================================
# WiFi USB dongles (broad support)
# ============================================================
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_RFKILL=y

# Realtek WiFi (most common R36S dongles)
CONFIG_RTL8XXXU=m
CONFIG_RTL8187=m
CONFIG_RTW88=m
CONFIG_RTW89=m

# MediaTek WiFi
CONFIG_MT7601U=m
CONFIG_MT76x0U=m
CONFIG_MT76x2U=m

# Atheros WiFi
CONFIG_ATH9K_HTC=m
CONFIG_ATH6KL=m

# Ralink WiFi
CONFIG_RT2X00=m
CONFIG_RT2800USB=m

# ============================================================
# GPU — Panfrost ONLY (disable Mali proprietary drivers)
# ============================================================
# CRITICAL: Rockchip BSP defconfig enables Mali proprietary drivers
# (MALI_MIDGARD, MALI400, etc.) which bind to the GPU BEFORE Panfrost.
# Mesa only has Panfrost userspace → GPU inaccessible → llvmpipe (software).
# Must explicitly disable ALL Mali proprietary drivers.
CONFIG_DRM_PANFROST=m
# CONFIG_MALI400 is not set
# CONFIG_MALI450 is not set
# CONFIG_MALI470 is not set
# CONFIG_MALI_MIDGARD is not set
# CONFIG_MALI_BIFROST is not set
# CONFIG_MALI_VALHALL is not set
# CONFIG_MALI_BASE_MODULES is not set

# ============================================================
# Framebuffer: fb0 via DRM emulation + fbcon
# DEFERRED_TAKEOVER=y: fbcon waits for text output before clearing
# screen. With quiet+ttyFIQ0, U-Boot logo persists until Plymouth
# takes DRM master. Plymouth handles splash via KMS/DRM natively.
# ============================================================
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=200
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y
# CONFIG_LOGO is not set

# ============================================================
# USB / OTG
# ============================================================
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_DUAL_ROLE=y

# ============================================================
# Filesystem support
# ============================================================
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_EXFAT_FS=m
CONFIG_NTFS3_FS=m

# ============================================================
# Systemd requirements (kernel 6.6 supports all)
# ============================================================
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y
CONFIG_MEMCG=y
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_FHANDLE=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_AUTOFS_FS=y
CONFIG_PROC_CHILDREN=y

# ============================================================
# Boot optimization: disable unused subsystems (R36S has no camera/RAID)
# ============================================================

# Camera/ISP — R36S has no camera sensor, saves ~0.3-0.5s probe time
# CONFIG_VIDEO_ROCKCHIP_CIF is not set
# CONFIG_VIDEO_ROCKCHIP_ISP is not set
# CONFIG_VIDEO_ROCKCHIP_ISPP is not set
# CONFIG_PHY_ROCKCHIP_CSI2_DPHY is not set

# RAID/LVM — unnecessary on single SD card, saves ~0.2s
# CONFIG_MD is not set

# ============================================================
# SIZE TRIM: PCI/NVMe/SATA/UFS — RK3326 has NONE (~2-3MB saved)
# ============================================================
# CONFIG_PCI is not set
# CONFIG_SATA_AHCI is not set
# CONFIG_SATA_AHCI_PLATFORM is not set
# CONFIG_ATA is not set
# CONFIG_SCSI_SPI_ATTRS is not set
# CONFIG_NVME_CORE is not set
# CONFIG_SCSI_UFS_BSG is not set
# CONFIG_SCSI_UFSHCD is not set
# CONFIG_SCSI_UFSHCD_PLATFORM is not set

# ============================================================
# SIZE TRIM: Debug/Tracing/Profiling — production device (~1-2MB)
# ============================================================
# CONFIG_FTRACE is not set
# CONFIG_DYNAMIC_DEBUG is not set
# CONFIG_SCHEDSTATS is not set
# CONFIG_PROFILING is not set
# CONFIG_PM_DEBUG is not set
# CONFIG_PM_ADVANCED_DEBUG is not set
# CONFIG_DEBUG_DEVRES is not set
# CONFIG_USB_GADGET_DEBUG_FILES is not set
# CONFIG_FW_LOADER_DEBUG is not set
# CONFIG_IKCONFIG is not set
# CONFIG_BLK_DEBUG_FS is not set
# CONFIG_SCHED_DEBUG is not set
# CONFIG_DEBUG_CREDENTIALS is not set
# CONFIG_RK_DMABUF_DEBUG is not set
# CONFIG_ROCKCHIP_DMC_DEBUG is not set
# CONFIG_ROCKCHIP_DEBUG is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_LKDTM is not set
# CONFIG_NET_SELFTESTS is not set
CONFIG_DEBUG_INFO_NONE=y
# CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT is not set

# ============================================================
# SIZE TRIM: Rockchip MPP for other SoCs (~1-2MB)
# Keep only VDPU2/VEPU2 (RK3326's actual VPU)
# ============================================================
# CONFIG_ROCKCHIP_MPP_RKVDEC is not set
# CONFIG_ROCKCHIP_MPP_RKVDEC2 is not set
# CONFIG_ROCKCHIP_MPP_RKVENC is not set
# CONFIG_ROCKCHIP_MPP_RKVENC2 is not set
# CONFIG_ROCKCHIP_MPP_VDPU1 is not set
# CONFIG_ROCKCHIP_MPP_VEPU1 is not set
# CONFIG_ROCKCHIP_MPP_IEP2 is not set
# CONFIG_ROCKCHIP_MPP_JPGDEC is not set
# CONFIG_ROCKCHIP_MPP_JPGENC is not set
# CONFIG_ROCKCHIP_MPP_AV1DEC is not set
# CONFIG_ROCKCHIP_MULTI_RGA is not set
# CONFIG_ROCKCHIP_RKNPU is not set
# CONFIG_IEP is not set

# ============================================================
# SIZE TRIM: Camera/ISP/DVB/sensors — none on R36S (~500KB-1MB)
# ============================================================
# CONFIG_VIDEO_ROCKCHIP_AIISP is not set
# CONFIG_VIDEO_ROCKCHIP_RKISP1 is not set
# CONFIG_VIDEO_ROCKCHIP_HDMIRX is not set
# CONFIG_VIDEO_ROCKCHIP_HDMIRX_CLASS is not set
# CONFIG_VIDEO_ROCKCHIP_VPSS is not set
# CONFIG_VIDEO_CAMERA_SENSOR is not set
# CONFIG_MEDIA_CAMERA_SUPPORT is not set
# CONFIG_MEDIA_ANALOG_TV_SUPPORT is not set
# CONFIG_MEDIA_DIGITAL_TV_SUPPORT is not set
# CONFIG_MEDIA_RADIO_SUPPORT is not set
# CONFIG_MEDIA_SDR_SUPPORT is not set
# CONFIG_MEDIA_TEST_SUPPORT is not set
# CONFIG_DVB_CORE is not set

# ============================================================
# SIZE TRIM: Display drivers — R36S uses ONLY MIPI DSI (~500KB-1MB)
# ============================================================
# CONFIG_ROCKCHIP_ANALOGIX_DP is not set
# CONFIG_ROCKCHIP_CDN_DP is not set
# CONFIG_ROCKCHIP_DRM_TVE is not set
# CONFIG_ROCKCHIP_DW_HDMI is not set
# CONFIG_ROCKCHIP_DW_DP is not set
# CONFIG_ROCKCHIP_INNO_HDMI is not set
# CONFIG_ROCKCHIP_LVDS is not set
# CONFIG_ROCKCHIP_RGB is not set
# CONFIG_ROCKCHIP_DW_HDCP2 is not set
# CONFIG_ROCKCHIP_DP_MST_AUX_CLIENT is not set
# CONFIG_ROCKCHIP_DW_MIPI_DSI2 is not set
# CONFIG_DRM_DP_AUX_CHARDEV is not set
# CONFIG_DRM_LOAD_EDID_FIRMWARE is not set
# CONFIG_DRM_SII902X is not set
# CONFIG_DRM_DW_HDMI is not set
# CONFIG_DRM_DW_HDMI_I2S_AUDIO is not set
# CONFIG_DRM_DW_HDMI_CEC is not set
# CONFIG_DRM_ANALOGIX_DP is not set
# CONFIG_DRM_DISPLAY_CONNECTOR is not set
# CONFIG_CEC_CORE is not set
# CONFIG_ROCKCHIP_SERDES_DRM_PANEL is not set
# CONFIG_MFD_RKX110_X120 is not set
# CONFIG_RK628_MISC is not set

# ============================================================
# SIZE TRIM: Ethernet/CAN — R36S has none (~500KB-1MB)
# ============================================================
# CONFIG_ETHERNET is not set
# CONFIG_CAN is not set
# CONFIG_PCS_XPCS is not set

# ============================================================
# SIZE TRIM: PHY drivers for other SoCs (~200-400KB)
# Keep: INNO_USB2 (OTG), INNO_DSIDPHY (DSI)
# ============================================================
# CONFIG_PHY_ROCKCHIP_DP is not set
# CONFIG_PHY_ROCKCHIP_EMMC is not set
# CONFIG_PHY_ROCKCHIP_INNO_HDMI is not set
# CONFIG_PHY_ROCKCHIP_INNO_USB3 is not set
# CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY is not set
# CONFIG_PHY_ROCKCHIP_NANENG_EDP is not set
# CONFIG_PHY_ROCKCHIP_PCIE is not set
# CONFIG_PHY_ROCKCHIP_SAMSUNG_DCPHY is not set
# CONFIG_PHY_ROCKCHIP_SAMSUNG_HDPTX is not set
# CONFIG_PHY_ROCKCHIP_SAMSUNG_HDPTX_HDMI is not set
# CONFIG_PHY_ROCKCHIP_SNPS_PCIE3 is not set
# CONFIG_PHY_ROCKCHIP_TYPEC is not set
# CONFIG_PHY_ROCKCHIP_USBDP is not set

# ============================================================
# SIZE TRIM: MTD/SPI flash — R36S boots from SD, no flash (~200-400KB)
# ============================================================
# CONFIG_MTD is not set

# ============================================================
# SIZE TRIM: Filesystems not needed (~300-500KB)
# ============================================================
# CONFIG_XFS_FS is not set
# CONFIG_ISO9660_FS is not set
# CONFIG_NTFS_FS is not set
# CONFIG_JFFS2_FS is not set
# CONFIG_UBIFS_FS is not set
# CONFIG_EFIVAR_FS is not set
# CONFIG_NFS_FS is not set
CONFIG_FUSE_FS=m
CONFIG_SQUASHFS=m

# ============================================================
# SIZE TRIM: Audio codecs for other boards (~200-400KB)
# Keep: RK817 codec, I2S_TDM, simple-card
# ============================================================
# CONFIG_SND_SOC_ROCKCHIP_ASRC is not set
# CONFIG_SND_SOC_ROCKCHIP_DLP_PCM is not set
# CONFIG_SND_SOC_ROCKCHIP_PDM is not set
# CONFIG_SND_SOC_ROCKCHIP_PDM_V2 is not set
# CONFIG_SND_SOC_ROCKCHIP_SAI is not set
# CONFIG_SND_SOC_ROCKCHIP_SPDIF is not set
# CONFIG_SND_SOC_ROCKCHIP_SPDIFRX is not set
# CONFIG_SND_SOC_ROCKCHIP_MAX98090 is not set
# CONFIG_SND_SOC_ROCKCHIP_MULTICODECS is not set
# CONFIG_SND_SOC_ROCKCHIP_RT5645 is not set
# CONFIG_SND_SOC_ROCKCHIP_HDMI is not set
# CONFIG_SND_SOC_DUMMY_CODEC is not set
# CONFIG_SND_SOC_ES7202 is not set
# CONFIG_SND_SOC_ES7243E is not set
# CONFIG_SND_SOC_ES8311 is not set
# CONFIG_SND_SOC_ES8316 is not set
# CONFIG_SND_SOC_ES8323 is not set
# CONFIG_SND_SOC_ES8326 is not set
# CONFIG_SND_SOC_RK3308 is not set
# CONFIG_SND_SOC_RK3328 is not set
# CONFIG_SND_SOC_RK3506 is not set
# CONFIG_SND_SOC_RK3528 is not set
# CONFIG_SND_SOC_RK_CODEC_DIGITAL is not set
# CONFIG_SND_SOC_RK_DSM is not set
# CONFIG_SND_SOC_RT5616 is not set
# CONFIG_SND_SOC_RT5640 is not set
# CONFIG_SND_SOC_RT5645 is not set
# CONFIG_SND_SOC_RT5651 is not set
# CONFIG_SND_SOC_SPDIF is not set
# CONFIG_SND_SOC_HDMI_CODEC is not set
# CONFIG_SND_SOC_MAX98090 is not set
# CONFIG_SND_SOC_TS3A227E is not set
